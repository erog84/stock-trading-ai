# ============================================================
# Stock Trading AI Platform - Environment Configuration
# ============================================================
# Copy this to .env and fill in your keys.
# Sources marked [FREE, NO KEY] work without any setup.

# --- Data Sources ---

# Alpha Vantage [FREE, 25 requests/day]
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# FRED - Federal Reserve Economic Data [FREE]
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_key_here

# QuiverQuant - Congressional Trading [PAID]
# Get key: https://www.quiverquant.com/
# Note: Free fallback scraping is available without this key
QUIVER_API_KEY=

# Yahoo Finance [FREE, NO KEY] - works automatically
# SEC EDGAR [FREE, NO KEY] - works automatically
# News RSS [FREE, NO KEY] - works automatically
# Options data [FREE, NO KEY] - uses yfinance

# --- Alpaca Broker ---
# Sign up: https://app.alpaca.markets/signup
# Then: Paper Trading > API Keys > Generate
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Broker type: paper (simulated), alpaca_paper, alpaca_live
BROKER_TYPE=paper

# --- Alerts ---
# Discord webhook for trade/error notifications (optional)
ALERT_WEBHOOK_URL=
# Email for daily P&L summary (optional)
ALERT_EMAIL_TO=

# --- Scheduler ---
# Enable daily automated pipeline (fetch, train, signal, execute)
SCHEDULER_ENABLED=false

# --- Cache ---
# How long to cache API responses (hours)
CACHE_TTL_HOURS=24

# --- General ---
ENV=development
LOG_LEVEL=INFO
